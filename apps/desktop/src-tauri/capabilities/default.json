  "identifier": "default",
  "description": "Default HOP desktop capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main", "main*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "log:default",
    "store:default",
    "window-state:default"
  ]
}
